# YouTube Data API v3 密钥
# 获取方式: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# QQ 邮箱授权码（不是登录密码！在 QQ 邮箱 → 设置 → 账户 → POP3/SMTP 中获取）
SMTP_PASSWORD=your_smtp_authorization_code_here

# 发件人邮箱（通常与 QQ 邮箱相同）
SMTP_SENDER=your_sender_email@example.com

# 通知收件箱
NOTIFICATION_RECIPIENT=your_recipient_email@example.com
